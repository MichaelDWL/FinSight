# FinSight — variaveis de ambiente (copiar para .env ou backend/.env)
NODE_ENV=development
PORT=3045
CORS_ORIGIN=http://localhost:5500
# === Banco de dados (PostgreSQL) ==========================================
# O codigo NAO muda entre ambientes: tudo abaixo controla dev x producao.
#
# Desenvolvimento (Docker Postgres local):
DATABASE_URL=postgres://finsight:finsight_dev_password@localhost:15432/finsight
DATABASE_SSL=false
#
# Producao (Supabase / Vercel) — use o pooler (porta 6543) em serverless:
# DATABASE_URL=postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:6543/postgres
# DATABASE_SSL=true
#
# DATABASE_SSL_CA=             # PEM do CA do Supabase quando quiser validar contra CA especifico
# DATABASE_SSL_INSECURE=false  # NUNCA true em producao (desabilita verificacao TLS — apenas testes)
#
# Tamanho do pool (escolhido automaticamente conforme o ambiente):
DB_POOL_MAX=10                 # long-running (Docker/VPS)
DB_POOL_MAX_SERVERLESS=2       # por instancia em serverless (Vercel/Lambda)
# ==========================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# RUNTIME=long
# REDIS_URL=redis://localhost:6379

MARKET_SCHEDULER_ENABLED=true
CRON_SECRET=dev-cron-secret-change-me
# MARKET_DATA_RETENTION_DAYS=365

# BRAPI_TOKEN=
UPLOAD_PROVIDER=stub

JWT_ACCESS_SECRET=substitua-por-segredo-aleatorio-access-min-32-chars
JWT_REFRESH_SECRET=substitua-por-segredo-aleatorio-refresh-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
CSRF_ENABLED=true

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
PASSWORD_RESET_EXPIRES_MINUTES=30
EMAIL_VERIFY_EXPIRES_HOURS=24
REQUIRE_EMAIL_VERIFIED=true
PRIVACY_POLICY_VERSION=1.0

RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_PASSWORD_RESET_MAX=5
RATE_LIMIT_REFRESH_MAX=30
RATE_LIMIT_ADMIN_MAX=120

# Seed admin: so com ALLOW_ADMIN_SEED=true (nunca automatico em producao)
ALLOW_ADMIN_SEED=true
ADMIN_SEED_NAME=Administrador
ADMIN_SEED_EMAIL=admin@finsight.local
ADMIN_SEED_PASSWORD=substitua-por-senha-forte-12chars

EMAIL_PROVIDER=console
EMAIL_FROM=FinSight <noreply@finsight.local>
APP_PUBLIC_URL=http://localhost:5500
# RESEND_API_KEY=
# SENTRY_DSN=
