# =====================================================================
# CONFIGURACOES DO SITE (modelo para rodar NO SEU COMPUTADOR)
# =====================================================================
# Copie este arquivo para ".env" (ou "backend/.env") e ajuste o que precisar.
# Onde tiver "substitua-..." troque pelo valor de verdade.
# =====================================================================

NODE_ENV=development
PORT=3045

# Endereco do site quando roda no seu computador.
CORS_ORIGIN=http://localhost:5500


# ---------------------------------------------------------------------
# BANCO DE DADOS (onde ficam guardados os dados)
# ---------------------------------------------------------------------
# Para testar no seu computador (banco local via Docker):
DATABASE_URL=postgres://finsight:finsight_dev_password@localhost:15432/finsight
DATABASE_SSL=false
#
# Para producao (Supabase na Vercel) — use a opcao "Transaction pooler" (:6543):
# DATABASE_URL=postgresql://postgres.<ref>:<senha>@aws-0-<regiao>.pooler.supabase.com:6543/postgres
# DATABASE_SSL=true
#
# Detalhes tecnicos do banco (nao precisa mexer):
# DATABASE_SSL_CA=
# DATABASE_SSL_INSECURE=false
DB_POOL_MAX=10
DB_POOL_MAX_SERVERLESS=2


# ---------------------------------------------------------------------
# LIMITES DE USO (protege contra abuso) — nao mexer
# ---------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_PASSWORD_RESET_MAX=5
RATE_LIMIT_REFRESH_MAX=30
RATE_LIMIT_ADMIN_MAX=120


# ---------------------------------------------------------------------
# EXTRAS (opcionais)
# ---------------------------------------------------------------------
# RUNTIME=long
# REDIS_URL=redis://localhost:6379
MARKET_SCHEDULER_ENABLED=true
CRON_SECRET=dev-cron-secret-change-me
# MARKET_DATA_RETENTION_DAYS=365
# BRAPI_TOKEN=
UPLOAD_PROVIDER=stub


# ---------------------------------------------------------------------
# SEGURANCA DO LOGIN (chaves secretas)
# ---------------------------------------------------------------------
# Em producao gere valores novos e aleatorios (nao use os "substitua-...").
JWT_ACCESS_SECRET=substitua-por-segredo-aleatorio-access-min-32-chars
JWT_REFRESH_SECRET=substitua-por-segredo-aleatorio-refresh-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
CSRF_ENABLED=true


# ---------------------------------------------------------------------
# REGRAS DE CONTA — nao mexer
# ---------------------------------------------------------------------
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
PASSWORD_RESET_EXPIRES_MINUTES=30
EMAIL_VERIFY_EXPIRES_HOURS=24
REQUIRE_EMAIL_VERIFIED=true
PRIVACY_POLICY_VERSION=1.0


# ---------------------------------------------------------------------
# USUARIO ADMINISTRADOR (o "dono" do site)
# ---------------------------------------------------------------------
# Troque o e-mail e a senha pelos seus.
ALLOW_ADMIN_SEED=true
ADMIN_SEED_NAME=Administrador
ADMIN_SEED_EMAIL=admin@finsight.local
ADMIN_SEED_PASSWORD=substitua-por-senha-forte-12chars


# ---------------------------------------------------------------------
# ENVIO DE E-MAILS (opcional)
# ---------------------------------------------------------------------
EMAIL_PROVIDER=console
EMAIL_FROM=FinSight <noreply@finsight.local>
APP_PUBLIC_URL=http://localhost:5500
# RESEND_API_KEY=
# SENTRY_DSN=
