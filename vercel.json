{
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/cron/market", "destination": "/api/cron/market" },
    { "source": "/api/(.*)", "destination": "/api/[...path]" },
    { "source": "/health", "destination": "/api/[...path]" },
    { "source": "/js/(.*)", "destination": "/frontend/js/$1" },
    { "source": "/style/(.*)", "destination": "/frontend/style/$1" },
    { "source": "/(.*)", "destination": "/frontend/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/market",
      "schedule": "0 6 * * *"
    }
  ]
}
