NODE_ENV=development
PORT=3045
CORS_ORIGIN=http://localhost:5500
DATABASE_URL=postgres://finsight:finsight_dev_password@localhost:15432/finsight
DATABASE_SSL=false
DB_POOL_MAX=10
# Em serverless (Vercel) o pool e limitado automaticamente; override opcional:
# DB_POOL_MAX_SERVERLESS=2
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Runtime: long (Docker/Railway/VPS) | serverless (Vercel/Lambda). Auto-detecta se omitido.
# RUNTIME=long

# Cache L2 + rate-limit compartilhado (opcional). Sem REDIS_URL: memoria por instancia.
# REDIS_URL=redis://localhost:6379

# Scheduler in-process (somente RUNTIME=long). Em serverless use Vercel Cron → /api/cron/market
MARKET_SCHEDULER_ENABLED=true
# Obrigatorio em producao para /api/cron/market (Vercel envia Authorization: Bearer $CRON_SECRET)
CRON_SECRET=dev-cron-secret-change-me

# Token opcional da BRAPI (https://brapi.dev). PETR4/VALE3 funcionam sem token; demais ativos exigem.
# BRAPI_TOKEN=seu_token_aqui

# Uploads — nunca em disco local (stub | cloudinary)
UPLOAD_PROVIDER=stub
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# --- Autenticacao / Seguranca ---
# PRODUCAO: obrigatorios e fortes (min 32 chars, sem placeholders).
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=substitua-por-segredo-aleatorio-access-min-32-chars
JWT_REFRESH_SECRET=substitua-por-segredo-aleatorio-refresh-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Em prod: COOKIE_SECURE=true e COOKIE_SAME_SITE=lax (mesmo dominio) ou none (cross-site HTTPS).
COOKIE_SECURE=true
COOKIE_SAME_SITE=none
# COOKIE_DOMAIN=
CSRF_ENABLED=true

LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15
PASSWORD_RESET_EXPIRES_MINUTES=30
EMAIL_VERIFY_EXPIRES_HOURS=24

RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_REGISTER_MAX=5
RATE_LIMIT_PASSWORD_RESET_MAX=5
RATE_LIMIT_REFRESH_MAX=30
RATE_LIMIT_ADMIN_MAX=120

# Seed do administrador (primeira inicializacao). Em producao use senha forte (>=12, sem palavras obvias).
ADMIN_SEED_NAME=Administrador
ADMIN_SEED_EMAIL=admin@finsight.local
ADMIN_SEED_PASSWORD=substitua-por-senha-forte-12chars

# Email (console | resend | nodemailer)
EMAIL_PROVIDER=console
EMAIL_FROM=FinSight <noreply@finsight.local>
APP_PUBLIC_URL=http://localhost:5500
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
