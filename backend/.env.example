NODE_ENV=development
PORT=3045
CORS_ORIGIN=*
DATABASE_URL=postgres://finsight:finsight_dev_password@localhost:15432/finsight
DATABASE_SSL=false
DB_POOL_MAX=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Cache de analytics (opcional). Sem REDIS_URL usa cache em memoria.
# REDIS_URL=redis://localhost:6379

# Scheduler de Market Data (BCB + BRAPI + Stooq complementar). Use false para desligar em testes.
MARKET_SCHEDULER_ENABLED=true

# Token opcional da BRAPI (https://brapi.dev). PETR4/VALE3 funcionam sem token; demais ativos exigem.
# BRAPI_TOKEN=seu_token_aqui
